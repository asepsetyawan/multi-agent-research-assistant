# Required: OpenAI-compatible API key
OPENAI_API_KEY=sk-...

# Optional: model override (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Optional: Tavily web search (recommended for real research)
# Without this key, the app uses mock search results for demos.
TAVILY_API_KEY=tvly-...

# Optional: LangSmith tracing for portfolio demos
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_...
LANGCHAIN_PROJECT=multi-agent-research-assistant
